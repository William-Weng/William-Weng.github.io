        class=&#34;image_figure image_internal image_unprocessed&#34;
        src=&#34;http://localhost:1313/image/2025/github-workflows-first/git-push.png&#34;
      
      
    /&gt;

    &lt;/picture&gt;
&lt;/figure&gt;
&lt;/p&gt;
          
          
        
